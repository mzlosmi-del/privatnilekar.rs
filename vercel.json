{
  "version": 2,
  "builds": [
    { "src": "landing.html", "use": "@vercel/static" },
    { "src": "index.html",   "use": "@vercel/static" },
    { "src": "admin.html",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",         "dest": "/landing.html" },
    { "src": "/app",      "dest": "/index.html" },
    { "src": "/app.html", "dest": "/index.html" },
    {
      "src": "/admin",
      "dest": "/admin.html",
      "headers": { "X-Robots-Tag": "noindex, nofollow" }
    },
    {
      "src": "/admin.html",
      "dest": "/admin.html",
      "headers": { "X-Robots-Tag": "noindex, nofollow" }
    },
    { "src": "/(.*)", "dest": "/landing.html" }
  ]
}
