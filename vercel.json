{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin.html",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow"
      }
    },
    {
      "src": "/admin.html",
      "dest": "/admin.html",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
